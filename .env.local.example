# .env.local.example
# Copy this file to .env.local and fill in your own values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Database (for local development with supabase cli)
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Vercel / Deployment
NEXT_PUBLIC_APP_URL=https://your-app-domain.vercel.app

# WhatsApp Integration (future)
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_BUSINESS_PHONE_ID=your-phone-id
WHATSAPP_BUSINESS_API_TOKEN=your-api-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-token

# Email Service (future - nodemailer, SendGrid, etc)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@estilo-alejandra.com

# Optional: Analytics
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Node environment
NODE_ENV=development
